---
interface Props {
  totalTools: number;
}

const { totalTools } = Astro.props as Props;
---

<div class="search-shell">
  <label class="search-label" for="search-input">Search the directory</label>
  <input
    id="search-input"
    class="search-input"
    type="search"
    name="search"
    placeholder="Search by tool, category, tag, or note..."
    autocomplete="off"
    spellcheck="false"
  />
  <p class="search-meta">
    <span id="search-count">{totalTools}</span>
    tools indexed
  </p>
</div>
