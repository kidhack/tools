---
import SearchBar from '../components/SearchBar.astro';
import TOC from '../components/TOC.astro';
import CategorySection from '../components/CategorySection.astro';
import { allTools, categories, totalTools } from '../data/tools';
import '../styles/global.css';

const title = 'Cool Tools';
const description =
  'A small collection of design focused tools.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="page-shell">
      <aside class="sidebar">
        <TOC categories={categories} />
      </aside>

      <main class="content">
        <header class="hero">
          <h1>{title}</h1>
          <p class="hero-copy">{description}</p>
          <SearchBar totalTools={totalTools} />
        </header>

        <div id="empty-state" class="empty-state" hidden>
          <p>No tools matched that search. Try a broader keyword or tag.</p>
        </div>

        <div id="tool-results">
          {categories.map((category) => (
            <CategorySection category={category} />
          ))}
        </div>
      </main>
    </div>

    <script id="tool-data" type="application/json" set:html={JSON.stringify(allTools)} />

    <script>
      import Fuse from 'fuse.js';

      const input = document.querySelector('#search-input');
      const count = document.querySelector('#search-count');
      const emptyState = document.querySelector('#empty-state');
      const cards = Array.from(document.querySelectorAll('[data-name]'));
      const sections = Array.from(document.querySelectorAll('[data-category-section]'));
      const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
      const toolData = JSON.parse(document.querySelector('#tool-data')?.textContent ?? '[]');

      const fuse = new Fuse(toolData, {
        includeScore: true,
        threshold: 0.34,
        ignoreLocation: true,
        keys: [
          { name: 'name', weight: 0.45 },
          { name: 'description', weight: 0.25 },
          { name: 'categoryLabel', weight: 0.15 },
          { name: 'tags', weight: 0.1 },
          { name: 'personalNote', weight: 0.05 },
        ],
      });

      const applyVisibility = (visibleNames) => {
        let visibleCount = 0;

        cards.forEach((card) => {
          const matches = visibleNames === null || visibleNames.has(card.dataset.name ?? '');
          card.hidden = !matches;
          if (matches) {
            visibleCount += 1;
          }
        });

        sections.forEach((section) => {
          const hasVisibleCards = Array.from(section.querySelectorAll('[data-name]')).some(
            (card) => !card.hidden,
          );
          section.hidden = !hasVisibleCards;
        });

        count.textContent = String(visibleCount);
        emptyState.hidden = visibleCount !== 0;
      };

      const setActiveToc = (sectionId) => {
        tocLinks.forEach((link) => {
          const isActive = link.getAttribute('data-toc-link') === sectionId;
          link.classList.toggle('is-active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };

      const updateActiveSection = () => {
        const visibleSections = sections.filter((section) => !section.hidden);
        if (visibleSections.length === 0) {
          return;
        }

        const isAtBottom =
          window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2;
        if (isAtBottom) {
          setActiveToc(visibleSections[visibleSections.length - 1].id);
          return;
        }

        const activationOffset = 240;
        const reachedSections = visibleSections.filter(
          (section) => section.getBoundingClientRect().top <= activationOffset,
        );
        const currentSection =
          reachedSections[reachedSections.length - 1] ?? visibleSections[0];

        setActiveToc(currentSection.id);
      };

      const sectionObserver = new IntersectionObserver(
        () => {
          updateActiveSection();
        },
        {
          rootMargin: '-20% 0px -60% 0px',
          threshold: [0, 0.25, 0.5, 1],
        },
      );

      sections.forEach((section) => sectionObserver.observe(section));

      applyVisibility(null);
      updateActiveSection();
      window.addEventListener('scroll', updateActiveSection, { passive: true });
      window.addEventListener('resize', updateActiveSection);

      input?.addEventListener('input', (event) => {
        const query = event.currentTarget instanceof HTMLInputElement ? event.currentTarget.value.trim() : '';

        if (!query) {
          applyVisibility(null);
          updateActiveSection();
          return;
        }

        const visibleNames = new Set(fuse.search(query).map((result) => result.item.name));
        applyVisibility(visibleNames);
        updateActiveSection();
      });
    </script>
  </body>
</html>
