---
import type { Category } from '../data/tools';

interface Props {
  categories: Category[];
}

const { categories } = Astro.props as Props;
---

<nav class="toc" aria-label="Tool categories">
  <ul class="toc-list">
    {categories.map((category) => (
      <li>
        <a href={`#${category.id}`} aria-label={category.label} data-toc-link={category.id}>
          <span class="toc-label">{category.label}</span>
          <span class="toc-tick" aria-hidden="true"></span>
        </a>
      </li>
    ))}
  </ul>
</nav>
