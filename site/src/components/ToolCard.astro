---
import type { Tool } from '../data/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props as Props;
const displayUrl = tool.url.replace(/^https?:\/\/(www\.)?/, '').replace(/\/+$/, '');
---

<article
  class="tool-card"
  data-name={tool.name}
  data-description={tool.description}
  data-tags={tool.tags?.join(',') ?? ''}
>
  <div class="tool-heading">
    <h3>
      <a href={tool.url} target="_blank" rel="noopener noreferrer">
        {tool.name}
      </a>
    </h3>
  </div>

  <p class="tool-url">
    <a href={tool.url} target="_blank" rel="noopener noreferrer">{displayUrl}</a>
  </p>

  <p class="tool-description">{tool.description}</p>
</article>
